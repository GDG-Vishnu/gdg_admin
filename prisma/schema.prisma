generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}
model TeamMember {
    id          String   @id @default(cuid())
    imageUrl    String
    logo        String?
    name        String
    designation String
    position    String? 
    linkedinUrl String?
    mail        String?
    dept_logo   String?
    bgColor     String?
    rank        Int      @default(0)
    dept_rank   Int      @default(0)
    @@index([name])
    @@map("team_members")
}

model Events {
    id                  String   @id @default(cuid())
    rank                Int      @default(0)
    title               String
    description         String
    Date                DateTime
    Time                String
    venue               String
    organizer           String
    coOrganizer         String?
    keyHighlights       String[]
    tags                String[]
    status              String
    eventGallery        String[]
    imageUrl            String?
    coverUrl            String?
    isDone              Boolean  @default(false)
    MembersParticipated Int      @default(0)
    Theme               String[]

    @@index([title])
}

model Gallery {
    id         Int      @id @default(autoincrement())
    imageUrl   String
    uploadedAt DateTime @default(now())
}

model User {
    id        String   @id @default(cuid())
    name      String
    email     String   @unique
    password  String
    isAdmin   Boolean  @default(false)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Form {
    id          String         @id @default(cuid())
    title       String
    description String?
    fields      Json           // Stores array of FormField objects (with stepId)
    steps       Json?          // Stores array of FormStep objects
    isActive    Boolean        @default(true)
    createdAt   DateTime       @default(now())
    updatedAt   DateTime       @updatedAt
    responses   FormResponse[]

    @@index([title])
    @@index([createdAt])
    @@map("forms")
}

model FormResponse {
    id          String   @id @default(cuid())
    formId      String
    form        Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
    data        Json     // Stores the complete response data
    submittedAt DateTime @default(now())

    @@index([formId])
    @@index([submittedAt])
    @@map("form_responses")
}